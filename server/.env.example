PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/afya
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# FCM (optional in dev). Leave FCM_ENABLED=false to stub.
FCM_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Seed admin
ADMIN_PHONE=+254700000000
ADMIN_PASSWORD=admin1234
ADMIN_NAME=Camp Admin

# --- Phase 5.2 SMS adapter (Twilio). Leave provider=stub to log to console. ---
SMS_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Phase 3.5 Email adapter. 'stub' logs to console; 'noop' silences. ---
EMAIL_PROVIDER=stub
EMAIL_FROM=noreply@afyaconnect.org
PUBLIC_APP_URL=http://localhost:5173

# --- Phase 4.3 Stripe (donations). Empty = fall back to stub provider. ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# --- Phase 4.3 Safaricom Daraja (M-Pesa STK push). Sandbox creds are fine. ---
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=

# In production, force a real provider so a misconfigured deploy can't
# silently serve the demo stub:
DONATIONS_REQUIRE_REAL=false

# --- Feature flags (default ON; set to false to disable) ---
AUDIT_ENABLED=true
REMINDERS_ENABLED=true
